pipeline {
    agent any

    tools {
        maven 'Maven-3'
        jdk 'JDK-21'
    }

    environment {
        EC2_HOST = "51.21.163.184"
        KEY_PATH = "C:\\Users\\kancharlarani\\keys\\my-app-key.pem"
    }

    stages {

        stage('Build') {
            steps {
                bat 'mvn -B -DskipTests clean package'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
            post {
                always {
                    junit 'target\\surefire-reports\\*.xml'
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar'
            }
        }

        stage('Deploy to EC2') {
            steps {
                bat """
                echo Copying JAR...

                scp -o StrictHostKeyChecking=no -i "%KEY_PATH%" target\\*.jar ec2-user@%EC2_HOST%:/home/ec2-user/app.jar

                echo Deploying...

                ssh -o StrictHostKeyChecking=no -i "%KEY_PATH%" ec2-user@%EC2_HOST% ^
                "pkill -f java || true; nohup java -jar app.jar > app.log 2>&1 &"

                echo Done
                """
            }
        }
    }
}